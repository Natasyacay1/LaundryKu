<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/bg_card_white" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Tambah Admin Baru" android:textColor="@color/teal_dark" android:textSize="18sp" android:textStyle="bold"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="14dp" android:text="Nama" android:textColor="@color/black" android:textSize="13sp" android:textStyle="bold"/>
    <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="6dp" android:background="@drawable/bg_input_field" android:hint="Nama admin"
        android:inputType="textPersonName" android:paddingStart="14dp" android:paddingEnd="14dp" android:textSize="14sp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="Email" android:textColor="@color/black" android:textSize="13sp" android:textStyle="bold"/>
    <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="6dp" android:background="@drawable/bg_input_field" android:hint="email@laundry.com"
        android:inputType="textEmailAddress" android:paddingStart="14dp" android:paddingEnd="14dp" android:textSize="14sp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="No. HP" android:textColor="@color/black" android:textSize="13sp" android:textStyle="bold"/>
    <EditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="6dp" android:background="@drawable/bg_input_field" android:hint="08xxxxxxxxxx"
        android:inputType="phone" android:paddingStart="14dp" android:paddingEnd="14dp" android:textSize="14sp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="Password" android:textColor="@color/black" android:textSize="13sp" android:textStyle="bold"/>
    <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="6dp" android:background="@drawable/bg_input_field" android:hint="Min. 6 karakter"
        android:inputType="textPassword" android:paddingStart="14dp" android:paddingEnd="14dp" android:textSize="14sp"/>
    <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="20dp" android:background="@drawable/bg_button_coral"
        android:text="TAMBAH ADMIN" android:textColor="@color/white" android:textStyle="bold"/>
    <TextView android:id="@+id/tvCancel" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="10dp" android:gravity="center" android:padding="8dp"
        android:text="Batal" android:textColor="@color/gray" android:textSize="13sp"/>
</LinearLayout>
