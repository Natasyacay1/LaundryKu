<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginTop="6dp" android:layout_marginBottom="6dp"
    android:background="@drawable/bg_card_white" android:elevation="2dp"
    android:gravity="center_vertical" android:orientation="horizontal" android:padding="14dp">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvCode" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/coral" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDesc" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="2dp" android:textColor="@color/gray" android:textSize="12sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:orientation="horizontal">
            <TextView android:id="@+id/tvValue" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/bg_card_teal_light" android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="2dp" android:paddingBottom="2dp" android:textColor="@color/teal_dark"
                android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvMin" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="8dp" android:textColor="@color/gray" android:textSize="11sp"/>
        </LinearLayout>
        <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="12sp" android:textStyle="bold"/>
    </LinearLayout>
    <ImageButton android:id="@+id/btnEdit" android:layout_width="30dp" android:layout_height="30dp"
        android:layout_marginEnd="4dp" android:background="@drawable/bg_icon_teal_light"
        android:src="@android:drawable/ic_menu_edit" android:tint="@color/teal"/>
    <ImageButton android:id="@+id/btnDelete" android:layout_width="30dp" android:layout_height="30dp"
        android:background="@drawable/bg_icon_red_light" android:src="@android:drawable/ic_menu_delete" android:tint="@color/coral"/>
</LinearLayout>
